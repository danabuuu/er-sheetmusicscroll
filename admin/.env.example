# Copy this to .env.local for local development.
# On Vercel, set these in the dashboard (they are NOT committed to source control).

# Supabase project URL — find in: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key — safe for server-side DB reads
SUPABASE_ANON_KEY=your-anon-key

# Supabase service-role key — bypasses RLS, used for Storage uploads
# KEEP SECRET — never expose in the browser or commit to git
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
